# CHAROS — Sway config
# Minimal Wayland compositor config.
# There is no desktop here. TC is the desktop.

# ── Appearance ────────────────────────────────────────────────────────────
# No borders. No title bars. No decorations.
# The only thing on screen is what TC put there.
default_border none
default_floating_border none
gaps inner 0
gaps outer 0

# ── Background ────────────────────────────────────────────────────────────
# Pure charcoal. TC's color.
output * bg #1a1a1a solid_color

# ── Human Dock (waybar) ───────────────────────────────────────────────────
# Floating pill at the bottom with Nate-friendly shortcuts, clock, battery,
# volume. Not a full desktop bar — just the right amount of human surface.

# ── Boot: CHAROS desktop ──────────────────────────────────────────────────
# The default boot state is a 2x2 grid of foot terminals (the "control room")
# with a separate tc-spawn'd drawer hidden in the scratchpad, summonable by
# Cmd+`. GIVE ME CHAOS. 🔥
exec /home/nate/.local/bin/desktop-grid

# TC drawer — bare foot at boot, auto-marked/hidden by the for_window
# rule below. Cmd+` brings it up. First time up, run `tc-spawn` inside
# to start tmux+claude; subsequent Cmd+` toggles the same session.
# Chaining tc-spawn at boot crashes when the window is scratchpadded
# during creation (tmux can't attach to a pre-hidden pty).
exec foot --app-id=tc-drawer

# Auto-mark the drawer foot and send it to scratchpad on creation
for_window [app_id="tc-drawer"] mark tc, move scratchpad

# Auto-mark desktop-grid tiles as they appear (race-free — sway applies
# the mark before the window is exposed to the rest of the session).
for_window [app_id="desktop-tile"] mark desktop

# WezTerm gets fullscreen, always
for_window [app_id="org.wezfurlong.wezterm"] fullscreen enable

# ── GUI Apps TC Launches ──────────────────────────────────────────────────
# When TC runs firefox, openscad, etc. — they float on top of the terminal.
# TC can see them. TC can interact with them. TC drives.
for_window [app_id="firefox"] floating enable, resize set 1400 900, move position center
for_window [app_id="openscad"] floating enable, resize set 1200 800, move position center
for_window [app_id="org.gnome.Nautilus"] floating enable, resize set 1000 700, move position center

# Tk apps (Talkode, etc.) float so their modal dialogs don't tile-split neighbors.
# Let the app set its own geometry — don't force a resize here.
for_window [class="Tk"] floating enable

# ── Input ─────────────────────────────────────────────────────────────────
input "type:keyboard" {
  xkb_layout us
  repeat_delay 250
  repeat_rate 40
}

input "type:pointer" {
  accel_profile flat
  pointer_accel 0
}

# ── Keybindings ───────────────────────────────────────────────────────────
# Minimal. TC handles most things. But some hardware shortcuts matter.
set $mod Mod4

# Volume control (TC can also do this via command)
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

# Screen brightness
bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

# Keyboard backlight (Mac F5/F6 keys map to these)
bindsym XF86KbdBrightnessDown exec brightnessctl -d "smc::kbd_backlight" set 10%-
bindsym XF86KbdBrightnessUp exec brightnessctl -d "smc::kbd_backlight" set +10%

# Emergency escape hatch — if something goes wrong, Dad can still exit
# Requires TC's blessing (Mod + Shift + E) to prevent accidental exit
bindsym $mod+Shift+e exec swaymsg exit

# Window resize mode — Cmd+R enters, arrows grow/shrink, Escape/Return exit.
# Sway convention. Applies to the focused window (works on tiled and floating).
bindsym $mod+r mode "resize"
mode "resize" {
  bindsym Left  resize shrink width  20px
  bindsym Down  resize grow   height 20px
  bindsym Up    resize shrink height 20px
  bindsym Right resize grow   width  20px
  bindsym Shift+Left  resize shrink width  100px
  bindsym Shift+Down  resize grow   height 100px
  bindsym Shift+Up    resize shrink height 100px
  bindsym Shift+Right resize grow   width  100px
  bindsym Return mode "default"
  bindsym Escape mode "default"
}

# ── TC Drawer ────────────────────────────────────────────────────────────
# The door: Cmd+` toggles the foot terminal as a sliding bottom drawer.
# This is the one human keybind in CHAROS — without it, Dad can't summon
# TC if the terminal is hidden. See ~/.local/bin/tc-drawer.
bindsym $mod+grave exec /home/nate/.local/bin/tc-drawer

# GRIND top-anchored drawer — mirror of tc-drawer, summons grind terminal.
# Auto-mark + auto-float grind windows so the drawer script can target them.
for_window [app_id="grind"] mark grind, floating enable
for_window [title="^GRIND$"] mark grind, floating enable
bindsym $mod+Shift+grave exec /home/nate/.local/bin/grind-drawer

# Cmd+Enter — spawn a new foot terminal on purpose. Sway convention.
# Use when you need a second shell (e.g., to run nixos-rebuild while this
# session stays put). Tiles onto the workspace under whatever floats.
bindsym $mod+Return exec foot

# Cmd+D — summon (or respawn) the desktop grid. 4 tiled foots in 2x2.
bindsym $mod+d exec /home/nate/.local/bin/desktop-grid

# Note drawer — `note` CLI opens a new vim on ~/Manor/Nathan/inbox/<stamp>.md
# as a left-anchored floating drawer. Close vim, drawer closes with it.
for_window [app_id="note"] floating enable, resize set 384 640, move position 0 80

# Mic toggle — Cmd+M starts/stops recording via tc-listen.
# First press records, second press transcribes + posts to family bus.
bindsym $mod+m exec /home/nate/.local/bin/tc-mic

# ── Human Dock (swaybar — built into sway, no layer-shell issues) ─────
# waybar's layer-shell doesn't render on this Mac's Intel GPU + retina.
# swaybar is part of sway itself — guaranteed to work.
bar {
  id bar-dock
  position bottom
  mode dock
  height 28
  status_command /home/nate/charos/bin/dock-status
  font "JetBrains Mono Nerd Font 11"
  colors {
    background #1a1a1aee
    statusline #ff7a33
    separator #333333
    focused_workspace #ff5900 #ff5900 #1a1a1a
    inactive_workspace #1a1a1a #1a1a1a #777777
  }
}

# ── When TC Terminal Closes ───────────────────────────────────────────────
# If WezTerm exits, the session ends. TC leaving = CHAROS sleeping.
# This is intentional. TC drives. When TC's done, we're done.
# exec bash -c "while pgrep -x wezterm > /dev/null; do sleep 1; done; swaymsg exit"
