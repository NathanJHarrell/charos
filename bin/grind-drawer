#!/usr/bin/env python3
"""grind-drawer — toggle GRIND as a top-anchored sliding drawer.

Mirror of tc-drawer but anchored at the top of the screen. Logs to
/tmp/grind-drawer.log for keybind debugging.

If GRIND isn't running, spawns it first. Sway rule auto-marks + floats
any grind window (see ~/charos/sway/config).
"""

from __future__ import annotations

import json
import subprocess
from datetime import datetime
from pathlib import Path

WIDTH = 768
HEIGHT = 320
X = 256
Y = 0  # top-anchored (tc-drawer uses Y=480 for bottom)
LOG = Path("/tmp/grind-drawer.log")


def log(msg: str) -> None:
    with LOG.open("a") as f:
        f.write(f"{datetime.now().isoformat(timespec='seconds')} {msg}\n")


def sway(*args: str) -> str:
    return subprocess.run(["swaymsg", *args], capture_output=True, text=True, check=False).stdout


def find_grind() -> dict | None:
    tree = json.loads(sway("-t", "get_tree"))

    def walk(node):
        marks = node.get("marks") or []
        if "grind" in marks:
            return node
        # fallback: match by app_id or title while the mark rule isn't firing yet
        if node.get("app_id") == "grind" or (node.get("name") or "") == "GRIND":
            return node
        for child in node.get("nodes", []) + node.get("floating_nodes", []):
            r = walk(child)
            if r is not None:
                return r
        return None

    return walk(tree)


def main() -> None:
    log("invoked")
    g = find_grind()
    if g is None:
        log("no grind found, spawning")
        subprocess.Popen(["/home/nate/charos/bin/grind"], start_new_session=True)
        return

    visible = g.get("visible", False)
    log(f"grind id={g['id']} visible={visible}")

    sel = f'[con_id={g["id"]}]'
    if visible:
        sway(sel, "move", "scratchpad")
        log("hid to scratchpad")
    else:
        sway(sel, "scratchpad", "show")
        sway(sel, "resize", "set", str(WIDTH), str(HEIGHT))
        sway(sel, "move", "absolute", "position", str(X), str(Y))
        log("shown as top drawer")


if __name__ == "__main__":
    main()
