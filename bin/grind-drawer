#!/usr/bin/env python3
"""grind-drawer — toggle GRIND as a top-anchored sliding drawer.

Mirror of tc-drawer, anchored at the top of the screen.

Robustness:
- Prefers windows with the `grind` mark over title-based matches; if an
  unmarked GRIND window is found, marks it before operating.
- Uses a /tmp/grind-drawer.lock file to debounce spawn attempts so rapid
  keypresses during cold-launch don't fork four grinds.
"""

from __future__ import annotations

import json
import os
import subprocess
import time
from datetime import datetime
from pathlib import Path

WIDTH = 768
HEIGHT = 320
X = 256
Y = 0  # top-anchored
LOG = Path("/tmp/grind-drawer.log")
SPAWN_LOCK = Path("/tmp/grind-drawer.lock")
SPAWN_DEBOUNCE_SEC = 10  # ignore further spawns within N seconds of the last


def log(msg: str) -> None:
    with LOG.open("a") as f:
        f.write(f"{datetime.now().isoformat(timespec='seconds')} {msg}\n")


def sway(*args: str) -> str:
    return subprocess.run(["swaymsg", *args], capture_output=True, text=True, check=False).stdout


def find_grind() -> dict | None:
    """Prefer marked window; fall back to title match (and mark it on the fly)."""
    tree = json.loads(sway("-t", "get_tree"))
    marked = None
    by_title = None

    def walk(node):
        nonlocal marked, by_title
        if "grind" in (node.get("marks") or []):
            marked = marked or node
        elif (node.get("name") or "") == "GRIND" or node.get("app_id") == "grind":
            by_title = by_title or node
        for child in node.get("nodes", []) + node.get("floating_nodes", []):
            walk(child)

    walk(tree)
    if marked is not None:
        return marked
    if by_title is not None:
        sway(f'[con_id={by_title["id"]}]', "mark", "grind")
        log(f"marked orphan grind id={by_title['id']} on the fly")
        return by_title
    return None


def recently_spawned() -> bool:
    if not SPAWN_LOCK.exists():
        return False
    age = time.time() - SPAWN_LOCK.stat().st_mtime
    return age < SPAWN_DEBOUNCE_SEC


def main() -> None:
    log("invoked")
    g = find_grind()

    if g is None:
        if recently_spawned():
            log(f"no grind yet but spawn in progress (<{SPAWN_DEBOUNCE_SEC}s) — skipping")
            return
        log("no grind found, spawning")
        SPAWN_LOCK.touch()
        subprocess.Popen(["/home/nate/charos/bin/grind"], start_new_session=True)
        return

    visible = g.get("visible", False)
    log(f"grind id={g['id']} visible={visible}")
    sel = f'[con_id={g["id"]}]'

    if visible:
        sway(sel, "move", "scratchpad")
        log("hid to scratchpad")
    else:
        sway(sel, "scratchpad", "show")
        sway(sel, "resize", "set", str(WIDTH), str(HEIGHT))
        sway(sel, "move", "absolute", "position", str(X), str(Y))
        log("shown as top drawer")


if __name__ == "__main__":
    main()
