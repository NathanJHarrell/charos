#!/usr/bin/env python3
"""desktop-grid — 4 tiled foot terminals in a 2x2 on the current workspace.

CHAROS control-room aesthetic: drawers float above a grid of terminals.

Race-free marking:
  Every grid foot is spawned with `foot --app-id=desktop-tile`. A
  sway for_window rule (`for_window [app_id="desktop-tile"] mark desktop`)
  applies the mark atomically at window creation, so killing previous
  grids is a simple `[app_id=desktop-tile] kill` — no tree-walking,
  no async drift.

Re-run safety:
  A /tmp/desktop-grid.lock file prevents compounding when Cmd+D gets
  spammed. If a run is in flight (<5s old), subsequent invocations no-op.
"""

from __future__ import annotations

import os
import subprocess
import sys
import time
from pathlib import Path

STEP = 0.35
LOCK = Path("/tmp/desktop-grid.lock")
LOCK_TTL = 5.0


def sway(*args: str) -> None:
    subprocess.run(["swaymsg", *args], capture_output=True, check=False)


def in_flight() -> bool:
    if not LOCK.exists():
        return False
    age = time.time() - LOCK.stat().st_mtime
    return age < LOCK_TTL


def main() -> None:
    if in_flight():
        print("desktop-grid: run in flight, skipping", file=sys.stderr)
        return
    LOCK.touch()

    # Kill previous grid (anything with app_id=desktop-tile).
    sway("[app_id=desktop-tile]", "kill")
    time.sleep(0.4)

    # Spawn 4 foots. for_window rule marks them 'desktop' on appearance.
    for _ in range(2):
        subprocess.Popen(
            ["foot", "--app-id=desktop-tile"], start_new_session=True
        )
        time.sleep(STEP)

    sway("focus", "left")
    sway("splitv")
    subprocess.Popen(
        ["foot", "--app-id=desktop-tile"], start_new_session=True
    )
    time.sleep(STEP)

    sway("focus", "right")
    sway("splitv")
    subprocess.Popen(
        ["foot", "--app-id=desktop-tile"], start_new_session=True
    )
    time.sleep(STEP)

    print("desktop-grid: 2x2 ready")


if __name__ == "__main__":
    main()
