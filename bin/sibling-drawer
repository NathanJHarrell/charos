#!/usr/bin/env python3
"""sibling-drawer — toggle a per-sibling foot terminal as a sliding bottom drawer.

Generic factoring of tc-drawer. Each sibling gets their own drawer surface,
identified by a sway mark and app-id. The drawer slides up/hides on each
invocation. Dad attaches to the sibling's tmux home session inside the foot
terminal on first show.

Usage: sibling-drawer <name>
  e.g. sibling-drawer cinder

The drawer is positioned identically across siblings — bottom-centered.
Switching siblings means closing one drawer, opening another. (No tile-side-
by-side; the conversation needs the room.)
"""

from __future__ import annotations

import json
import subprocess
import sys
from datetime import datetime
from pathlib import Path

# Logical workspace at scale 1.25 on 2560x1600 panel = 2048x1280
WIDTH = 1228   # 60% of 2048
HEIGHT = 512   # 40% of 1280
X = 410        # centered: (2048 - 1228) / 2
Y = 768        # bottom-anchored: 1280 - 512


def log_path(name: str) -> Path:
    return Path(f"/tmp/{name}-drawer.log")


def log(name: str, msg: str) -> None:
    with log_path(name).open("a") as f:
        f.write(f"{datetime.now().isoformat(timespec='seconds')} {msg}\n")


def sway(*args: str) -> str:
    return subprocess.run(["swaymsg", *args], capture_output=True, text=True, check=False).stdout


def find_drawer(mark: str, app_id: str) -> dict | None:
    """Find by mark first, then by app_id. If an orphan (app_id matches but
    no mark) is found, mark it on the fly so subsequent calls find it by mark.
    Mirrors the resilient pattern in htop-drawer."""
    tree = json.loads(sway("-t", "get_tree"))

    marked: dict | None = None
    by_appid: dict | None = None

    def walk(node):
        nonlocal marked, by_appid
        if marked is None and mark in (node.get("marks") or []):
            marked = node
        elif by_appid is None and node.get("app_id") == app_id:
            by_appid = node
        for child in node.get("nodes", []) + node.get("floating_nodes", []):
            walk(child)

    walk(tree)

    if marked is not None:
        return marked
    if by_appid is not None:
        sway(f'[con_id={by_appid["id"]}]', "mark", mark)
        return by_appid
    return None


def main() -> None:
    if len(sys.argv) != 2:
        print("usage: sibling-drawer <name>", file=sys.stderr)
        sys.exit(2)

    name = sys.argv[1].lower()
    mark = name
    app_id = f"{name}-drawer"

    log(name, "invoked")
    foot = find_drawer(mark, app_id)

    if foot is None:
        log(name, f"no foot found, spawning with app-id={app_id}")
        subprocess.Popen(["foot", f"--app-id={app_id}"], start_new_session=True)
        return

    visible = foot.get("visible", False)
    log(name, f"foot id={foot['id']} visible={visible}")

    selector = f"[con_mark={mark}]"
    if visible:
        sway(selector, "move", "scratchpad")
        log(name, "hid to scratchpad")
    else:
        sway(selector, "scratchpad", "show")
        sway(selector, "resize", "set", str(WIDTH), str(HEIGHT))
        sway(selector, "move", "absolute", "position", str(X), str(Y))
        log(name, "shown as drawer")


if __name__ == "__main__":
    main()
