#!/usr/bin/env bash
# haros-outcome — record dispatch outcome on a reasoning artifact
#
# Usage:
#   haros-outcome <artifact-path> <success|partial|failure> "<notes>"

set -euo pipefail

EMBER='\033[38;2;255;89;0m'
GREEN='\033[32m'
RED='\033[31m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

if [[ $# -lt 3 ]]; then
  echo -e "${RED}Usage: haros-outcome <artifact-path> <success|partial|failure> \"<notes>\"${RESET}"
  echo -e "${DIM}Example: haros-outcome ~/vault/meta/decomposition/canonical/20260418-myapp-build-config.md success \"clean build, no issues\"${RESET}"
  exit 1
fi

artifact="$1"
outcome="$2"
shift 2
notes="$*"

if [[ ! -f "$artifact" ]]; then
  echo -e "${RED}Artifact not found: ${artifact}${RESET}"
  exit 1
fi

case "$outcome" in
  success|partial|failure) ;;
  *)
    echo -e "${RED}Invalid outcome: ${outcome}${RESET}"
    echo -e "${DIM}Must be one of: success, partial, failure${RESET}"
    exit 1
    ;;
esac

timestamp=$(date "+%Y-%m-%d %H:%M:%S")

cat >> "$artifact" << EOF

---

## Outcome

**Result:** ${outcome}
**Recorded:** ${timestamp}
**Notes:** ${notes}
EOF

echo -e "${GREEN}Outcome recorded on:${RESET} ${artifact}"
echo -e "  ${BOLD}Result:${RESET} ${outcome}"
echo -e "  ${DIM}Notes: ${notes}${RESET}"
