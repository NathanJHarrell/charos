#!/run/current-system/sw/bin/bash
# dock-status — swaybar status line with clickable i3bar JSON protocol.
#
# Architecture (third attempt, nate-proofed):
#   - Status loop runs in BACKGROUND, writes JSON to stdout
#   - Click handler runs in FOREGROUND, reads stdin from swaybar
#   - Click handler's stdout/stderr → /dev/null so errors never
#     corrupt the JSON stream that swaybar is parsing

# ── Status output (background, owns stdout) ──────────────────────────
status_loop() {
  echo '{"version":1,"click_events":true}'
  echo '['
  echo '[]'

  while true; do
    BAT=$(cat /sys/class/power_supply/*/capacity 2>/dev/null | head -1)
    BATSTAT=$(cat /sys/class/power_supply/*/status 2>/dev/null | head -1)
    case "$BATSTAT" in
      Charging) BATICON="⚡" ;; Full) BATICON="✓" ;; *) BATICON="🔋" ;;
    esac
    [ "${BAT:-100}" -lt 20 ] 2>/dev/null && BATCOLOR="#cc4444" || BATCOLOR="#66cc88"

    VOL=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | awk '{printf "%.0f", $2*100}')

    if systemctl is-active --quiet wg-quick-proton-us-nj 2>/dev/null; then
      VPN='{"full_text":" 🛡️ VPN ","name":"vpn","color":"#66cc88"},'
    else VPN=""; fi

    TIME=$(date +'%a %b %d  %I:%M %p')

    UNREAD=$(curl -sf http://127.0.0.1:4318/inbox/Nathan 2>/dev/null | jq -r '.unread_count // 0' 2>/dev/null)
    if [ "${UNREAD:-0}" -gt 0 ] 2>/dev/null; then
      BUS='{"full_text":" 💬 '"${UNREAD}"' ","name":"bus","color":"#ff7a33"},'
    else BUS=""; fi

    cat << BLOCK
,[
  {"full_text":" 🦊 ","name":"firefox","color":"#ff7a33"},
  {"full_text":" 📝 ","name":"note","color":"#e0e0e0"},
  {"full_text":" 🏠 ","name":"home","color":"#e0e0e0"},
  {"full_text":" 📊 ","name":"htop","color":"#e0e0e0"},
  {"full_text":" 🔥 ","name":"tc","color":"#ff5900"},
  {"full_text":" ⚡ ","name":"grind","color":"#cca000"},
  ${BUS}${VPN}{"full_text":" 🔊${VOL}% ","name":"volume","color":"#aaaaaa"},
  {"full_text":" ${BATICON}${BAT}% ","name":"battery","color":"${BATCOLOR}"},
  {"full_text":" ${TIME} ","name":"clock","color":"#ff7a33"}
]
BLOCK
    sleep 30
  done
}

# Launch status in background — it writes to real stdout (fd 1)
status_loop &

# ── Click handler (foreground, reads stdin, stdout silenced) ──────────
# First line from swaybar is '[' (opening click event array)
read -r _opening_bracket

while IFS= read -r line; do
  line="${line#,}"
  [ -z "$line" ] && continue
  NAME=$(echo "$line" | jq -r '.name // empty' 2>/dev/null) || continue
  [ -z "$NAME" ] && continue
  case "$NAME" in
    firefox) swaymsg -q exec firefox ;;
    note)    swaymsg -q exec note ;;
    home)    swaymsg -q exec 'foot -- bash -c "cd ~/Manor/Nathan && exec bash"' ;;
    htop)    swaymsg -q exec 'foot --app-id=htop-dock -- htop' ;;
    tc)      /home/nate/.local/bin/tc-drawer ;;
    grind)   /home/nate/.local/bin/grind-drawer ;;
    volume)  wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle ;;
    vpn)     /home/nate/.local/bin/vpn toggle ;;
    bus)     swaymsg -q exec 'foot -- bash -c "PATH=$HOME/.local/bin:$PATH bus recv --all --limit 20; read -p \"Press enter...\""' ;;
  esac
done >/dev/null 2>&1
