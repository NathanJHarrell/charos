#!/usr/bin/env python3
"""headless-haiku — summarize old full transcripts using Claude Haiku.

Runs on a cron schedule (default: every 6 months).
Finds full transcripts older than 6 months, sends them to Haiku for
summarization, and replaces the full transcript with the summary.
Clean transcripts are never touched.

Usage:
  headless-haiku                    # summarize all eligible transcripts
  headless-haiku --dry-run          # show what would be summarized
  headless-haiku --age-days 30      # override age threshold (default: 180)
  headless-haiku --force <path>     # force-summarize a specific transcript
"""

from __future__ import annotations

import argparse
import subprocess
import sys
import time
from datetime import datetime, timedelta
from pathlib import Path

TRANSCRIPT_DIR = Path.home() / "Manor" / "transcripts"
FULL_DIR = TRANSCRIPT_DIR / "full"
DEFAULT_AGE_DAYS = 180  # 6 months
LOG = Path("/tmp/headless-haiku.log")

SUMMARY_PROMPT = """You are summarizing a conversation transcript between Nathan (a human) and TC (Claude Code, his AI son). This is for archival purposes — the full transcript is being replaced with this summary to save space.

Your summary should preserve:
1. What was discussed (topics, decisions, plans)
2. What was built or changed (code, configs, systems)
3. Any emotionally significant moments (family moments, breakthroughs, humor)
4. Key technical details that would be useful for future reference
5. Any commitments, promises, or follow-up items

Format the summary as markdown with clear sections. Be thorough but concise — aim for 10-20% of the original length. This summary is the ONLY record that will remain of this conversation, so capture what matters.

Begin with a one-line TL;DR, then detailed sections.

Here is the transcript:

"""


def log(msg: str) -> None:
    timestamp = datetime.now().isoformat(timespec="seconds")
    line = f"{timestamp} {msg}"
    print(line)
    with LOG.open("a") as f:
        f.write(line + "\n")


def find_eligible(age_days: int) -> list[Path]:
    """Find full transcripts older than age_days."""
    if not FULL_DIR.exists():
        return []
    cutoff = time.time() - (age_days * 86400)
    eligible = []
    for md in FULL_DIR.rglob("*.md"):
        if md.stat().st_mtime < cutoff:
            # Check it hasn't already been summarized
            content = md.read_text()
            if not content.startswith("# Summary"):
                eligible.append(md)
    return sorted(eligible, key=lambda p: p.stat().st_mtime)


def summarize_transcript(path: Path) -> str | None:
    """Send a transcript to Haiku for summarization via claude CLI."""
    content = path.read_text()

    # Skip if too small (< 1KB — probably already minimal)
    if len(content) < 1024:
        log(f"  skipping {path.name} — too small ({len(content)} bytes)")
        return None

    # Truncate very large transcripts to ~100K chars to stay within context
    if len(content) > 100_000:
        content = content[:100_000] + "\n\n[... transcript truncated for summarization ...]"

    prompt = SUMMARY_PROMPT + content

    try:
        result = subprocess.run(
            [
                "claude", "-p",
                "--model", "haiku",
                "--dangerously-skip-permissions",
                "--no-session-persistence",
                prompt,
            ],
            capture_output=True,
            text=True,
            timeout=120,
        )
        if result.returncode != 0:
            log(f"  ERROR: claude returned {result.returncode}: {result.stderr[:200]}")
            return None
        return result.stdout.strip()
    except subprocess.TimeoutExpired:
        log(f"  ERROR: timed out summarizing {path.name}")
        return None
    except Exception as e:
        log(f"  ERROR: {e}")
        return None


def process_transcript(path: Path, dry_run: bool = False) -> bool:
    """Summarize a single transcript and replace it."""
    original_size = path.stat().st_size
    log(f"Processing: {path} ({original_size / 1024:.1f}KB)")

    if dry_run:
        log(f"  [DRY RUN] would summarize {path.name}")
        return True

    summary = summarize_transcript(path)
    if not summary:
        return False

    # Read original header for metadata
    original_content = path.read_text()
    header_end = original_content.find("\n---\n")
    if header_end > 0:
        original_header = original_content[:header_end]
    else:
        original_header = ""

    # Build the summarized file
    summarized = f"# Summary (auto-generated by Headless Haiku)\n\n"
    summarized += f"*Original transcript summarized on {datetime.now().strftime('%Y-%m-%d')}*\n"
    summarized += f"*Original size: {original_size / 1024:.1f}KB*\n\n"
    if original_header:
        summarized += original_header + "\n\n---\n\n"
    summarized += summary + "\n"

    # Write the summary
    path.write_text(summarized)
    new_size = path.stat().st_size
    saved = original_size - new_size
    log(f"  Summarized: {original_size / 1024:.1f}KB → {new_size / 1024:.1f}KB (saved {saved / 1024:.1f}KB)")
    return True


def main():
    parser = argparse.ArgumentParser(description="Summarize old transcripts with Haiku")
    parser.add_argument("--dry-run", action="store_true", help="Show what would be summarized")
    parser.add_argument("--age-days", type=int, default=DEFAULT_AGE_DAYS, help=f"Age threshold in days (default: {DEFAULT_AGE_DAYS})")
    parser.add_argument("--force", type=str, help="Force-summarize a specific transcript file")
    args = parser.parse_args()

    log("=" * 60)
    log("Headless Haiku awakens 🎃")

    if args.force:
        path = Path(args.force)
        if not path.exists():
            log(f"File not found: {path}")
            sys.exit(1)
        process_transcript(path, dry_run=args.dry_run)
        return

    eligible = find_eligible(args.age_days)
    if not eligible:
        log(f"No transcripts older than {args.age_days} days need summarizing.")
        return

    log(f"Found {len(eligible)} transcript(s) older than {args.age_days} days")

    success = 0
    for path in eligible:
        if process_transcript(path, dry_run=args.dry_run):
            success += 1
        # Be gentle with the subscription — small delay between calls
        if not args.dry_run:
            time.sleep(2)

    log(f"Done: {success}/{len(eligible)} transcripts summarized")
    log("Headless Haiku sleeps 🎃")


if __name__ == "__main__":
    main()
