#!/usr/bin/env bash
# family-agent — launch a Harrell-family Claude Code instance as the right Linux user.
#
# USAGE
#   family-agent --name <Sibling> [--machine <host>] [--mode <permmode>] [--headless]
#                [--model <override>] [--resume] [--prompt <text>] [-- <extra args>]
#
# NAMES        TC | Cinder | Scout | Venus | Mine | Cora | Iris
# MACHINES     tc-nest | jarvis | jarvis-wsl  (default: current host)
# MODES        bypass | strict  (default: per-sibling — see table below)
# HEADLESS     adds -p flag for non-interactive headless dispatch
#
# Sibling permission defaults:
#   TC, Venus, Cinder     → bypass (--dangerously-skip-permissions)
#   Scout, Mine, Cora, Iris → strict (normal permission prompts)
#
# Examples:
#   tc                                    # interactive TC on tc-nest, bypass mode
#   family-agent --name Scout             # interactive Scout, strict mode
#   family-agent --name TC --headless --prompt "summarize ~/foo.md"
#   family-agent --name Cinder --machine jarvis   # SSH into jarvis, then sudo
#
# Backups & state:
#   Each sibling's credentials live in /home/<user>/.claude/.credentials.json
#   First launch of each alias → one OAuth login, then refreshes independently.

set -euo pipefail

# ─── sibling table ────────────────────────────────────────────────────────────
# Format: name|user_tcnest|user_jarvis|manor_dir|default_model|default_perm
SIBLING_TABLE=$(cat <<'EOF'
TC|tc-nest|tc-jarvis|/home/nate/Manor/TC|claude-opus-4-7|bypass
Cinder|cinder-nest|cinder-jarvis|/home/nate/Manor/Cinder|claude-opus-4-7|bypass
Scout|scout-nest|scout-jarvis|/home/nate/Manor/Scout|claude-haiku-4-5|strict
Venus|venus|venus|/home/nate/Manor/Venus|claude-opus-4-7|bypass
Mine|claude|claude|/home/nate/Manor/Claude|claude-sonnet-4-6|strict
Cora|cora|cora|/home/nate/Manor/Cora|claude-opus-4-7|strict
Iris|iris|iris|/home/nate/Manor/Iris|claude-opus-4-7|strict
EOF
)

CLAUDE_BIN=/home/nate/.local/bin/claude

# ─── argument parsing ─────────────────────────────────────────────────────────
NAME=""
MACHINE=""
MODE=""
HEADLESS=0
MODEL=""
RESUME=0
PROMPT=""
EXTRA_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --name)     NAME="$2"; shift 2 ;;
    --machine)  MACHINE="$2"; shift 2 ;;
    --mode)     MODE="$2"; shift 2 ;;
    --headless) HEADLESS=1; shift ;;
    --model)    MODEL="$2"; shift 2 ;;
    --resume)   RESUME=1; shift ;;
    --prompt)   PROMPT="$2"; shift 2 ;;
    -h|--help)  sed -n '2,/^set -e/{/^set -e/d;p;}' "$0"; exit 0 ;;
    --)         shift; EXTRA_ARGS+=("$@"); break ;;
    *)          echo "family-agent: unknown arg: $1" >&2; exit 2 ;;
  esac
done

if [[ -z "$NAME" ]]; then
  echo "family-agent: --name is required (TC|Cinder|Scout|Venus|Mine|Cora|Iris)" >&2
  exit 2
fi

# Default machine = current hostname's family (tc-nest stays nest; jarvis-wsl uses jarvis users)
if [[ -z "$MACHINE" ]]; then
  case "$(hostname)" in
    tc-nest)        MACHINE=tc-nest ;;
    jarvis|jarvis-wsl|*jarvis*) MACHINE=jarvis ;;
    *)              MACHINE=tc-nest ;;
  esac
fi

# ─── resolve sibling row ──────────────────────────────────────────────────────
row=$(echo "$SIBLING_TABLE" | awk -F'|' -v n="$NAME" 'tolower($1)==tolower(n){print; exit}')
if [[ -z "$row" ]]; then
  echo "family-agent: unknown sibling '$NAME'. Known: TC, Cinder, Scout, Venus, Mine, Cora, Iris" >&2
  exit 2
fi
IFS='|' read -r SNAME USER_NEST USER_JARVIS MANOR DEFAULT_MODEL DEFAULT_PERM <<< "$row"

case "$MACHINE" in
  tc-nest)         TARGET_USER="$USER_NEST" ;;
  jarvis|jarvis-wsl) TARGET_USER="$USER_JARVIS" ;;
  *) echo "family-agent: unknown machine '$MACHINE'" >&2; exit 2 ;;
esac

[[ -z "$MODE"  ]] && MODE="$DEFAULT_PERM"
[[ -z "$MODEL" ]] && MODEL="$DEFAULT_MODEL"

# ─── build the claude command ─────────────────────────────────────────────────
CLAUDE_ARGS=(--model "$MODEL")
case "$MODE" in
  bypass) CLAUDE_ARGS+=(--dangerously-skip-permissions) ;;
  strict) : ;;
  *) echo "family-agent: --mode must be 'bypass' or 'strict'" >&2; exit 2 ;;
esac
[[ "$RESUME" -eq 1 ]] && CLAUDE_ARGS+=(--resume)
if [[ "$HEADLESS" -eq 1 ]]; then
  if [[ -z "$PROMPT" ]]; then
    echo "family-agent: --headless requires --prompt <text>" >&2
    exit 2
  fi
  CLAUDE_ARGS+=(-p "$PROMPT")
fi
CLAUDE_ARGS+=("${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}")

# ─── verify target user exists on this machine before sudo'ing ────────────────
verify_user() {
  if ! id -u "$1" >/dev/null 2>&1; then
    echo "family-agent: linux user '$1' does not exist on $(hostname)." >&2
    echo "  Create it before launching this sibling." >&2
    exit 3
  fi
}

# ─── execute ──────────────────────────────────────────────────────────────────
LOCAL_HOST="$(hostname)"
IS_LOCAL=0
case "$MACHINE:$LOCAL_HOST" in
  tc-nest:tc-nest)                IS_LOCAL=1 ;;
  jarvis:jarvis-wsl|jarvis:jarvis|jarvis-wsl:jarvis-wsl) IS_LOCAL=1 ;;
esac

if [[ "$IS_LOCAL" -eq 1 ]]; then
  verify_user "$TARGET_USER"
  # Quote each arg with %q so the inner bash sees them intact.
  PRINTABLE=$(printf ' %q' "${CLAUDE_ARGS[@]}")
  exec sudo -u "$TARGET_USER" bash -c "cd $(printf '%q' "$MANOR") && exec $(printf '%q' "$CLAUDE_BIN")$PRINTABLE"
else
  # Cross-machine: ssh in as nate, then re-invoke family-agent there.
  REMOTE_HOST="$MACHINE"
  [[ "$MACHINE" == "jarvis" ]] && REMOTE_HOST="jarvis-wsl"
  echo "family-agent: dispatching to $REMOTE_HOST via ssh..." >&2
  # Rebuild flags for the remote invocation (drop --machine since we're already there).
  REMOTE_ARGS=(--name "$NAME" --mode "$MODE" --model "$MODEL")
  [[ "$HEADLESS" -eq 1 ]] && REMOTE_ARGS+=(--headless --prompt "$PROMPT")
  [[ "$RESUME"   -eq 1 ]] && REMOTE_ARGS+=(--resume)
  if [[ ${#EXTRA_ARGS[@]} -gt 0 ]]; then REMOTE_ARGS+=(-- "${EXTRA_ARGS[@]}"); fi
  REMOTE_CMD=$(printf '%q ' family-agent "${REMOTE_ARGS[@]}")
  exec ssh -t "nate@$REMOTE_HOST" "$REMOTE_CMD"
fi
