#!/usr/bin/env python3
"""htop-drawer — toggle htop as a right-anchored sliding drawer.

Faded orange foot terminal running htop. Right side of the screen.
Dad's data porn on demand.
"""

from __future__ import annotations

import json
import subprocess
import time
from datetime import datetime
from pathlib import Path

# Right-side drawer: ~45% width, full height
SCREEN_W = 1280
SCREEN_H = 800
WIDTH = 576          # ~45% of 1280
HEIGHT = SCREEN_H    # full height
X = SCREEN_W - WIDTH  # right-anchored: 1280 - 576 = 704
Y = 0
MARK = "htop-drawer"
LOG = Path("/tmp/htop-drawer.log")
SPAWN_LOCK = Path("/tmp/htop-drawer.lock")
SPAWN_DEBOUNCE_SEC = 5


def log(msg: str) -> None:
    with LOG.open("a") as f:
        f.write(f"{datetime.now().isoformat(timespec='seconds')} {msg}\n")


def sway(*args: str) -> str:
    return subprocess.run(["swaymsg", *args], capture_output=True, text=True, check=False).stdout


def find_htop() -> dict | None:
    """Find the htop drawer by mark or app_id."""
    tree = json.loads(sway("-t", "get_tree"))
    marked = None
    by_appid = None

    def walk(node):
        nonlocal marked, by_appid
        if MARK in (node.get("marks") or []):
            marked = marked or node
        elif node.get("app_id") == "htop-drawer":
            by_appid = by_appid or node
        for child in node.get("nodes", []) + node.get("floating_nodes", []):
            walk(child)

    walk(tree)
    if marked is not None:
        return marked
    if by_appid is not None:
        sway(f'[con_id={by_appid["id"]}]', "mark", MARK)
        log(f"marked orphan htop id={by_appid['id']} on the fly")
        return by_appid
    return None


def recently_spawned() -> bool:
    if not SPAWN_LOCK.exists():
        return False
    age = time.time() - SPAWN_LOCK.stat().st_mtime
    return age < SPAWN_DEBOUNCE_SEC


def main() -> None:
    log("invoked")
    h = find_htop()

    if h is None:
        if recently_spawned():
            log(f"no htop yet but spawn in progress (<{SPAWN_DEBOUNCE_SEC}s) — skipping")
            return
        log("no htop found, spawning")
        SPAWN_LOCK.touch()
        subprocess.Popen(
            [
                "foot",
                "--app-id=htop-drawer",
                "--config=/home/nate/.config/foot/htop-drawer.ini",
                "--title=HTOP",
                "-e", "htop",
            ],
            start_new_session=True,
        )
        return

    visible = h.get("visible", False)
    log(f"htop id={h['id']} visible={visible}")
    sel = f'[con_id={h["id"]}]'

    if visible:
        sway(sel, "move", "scratchpad")
        log("hid to scratchpad")
    else:
        sway(sel, "scratchpad", "show")
        sway(sel, "resize", "set", str(WIDTH), str(HEIGHT))
        sway(sel, "move", "absolute", "position", str(X), str(Y))
        log("shown as right drawer")


if __name__ == "__main__":
    main()
