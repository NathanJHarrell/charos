#!/usr/bin/env python3
"""jukebox — CLI for the CHAROS YouTube Music integration.

Usage:
  jukebox                          # now playing
  jukebox history                  # recent history
  jukebox search "query"           # search songs
  jukebox search "query" --type albums  # search albums
  jukebox playlists                # list playlists
  jukebox playlist <id>            # show playlist tracks
  jukebox like <video_id>          # like a song
  jukebox recommend                # get recommendations
"""

import json
import sys
import urllib.request
import urllib.parse
import urllib.error

BASE = "http://localhost:4319"


def _get(path: str, params: dict = None) -> dict:
    url = f"{BASE}{path}"
    if params:
        url += "?" + urllib.parse.urlencode(params)
    try:
        with urllib.request.urlopen(url, timeout=10) as r:
            return json.loads(r.read())
    except urllib.error.URLError:
        print("❌ Jukebox is offline. Run: ~/charos/jukebox/start.sh")
        sys.exit(1)


def _post(path: str, data: dict) -> dict:
    body = json.dumps(data).encode()
    req = urllib.request.Request(f"{BASE}{path}", data=body, headers={"Content-Type": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=10) as r:
            return json.loads(r.read())
    except urllib.error.URLError:
        print("❌ Jukebox is offline. Run: ~/charos/jukebox/start.sh")
        sys.exit(1)


def cmd_now_playing():
    data = _get("/now-playing")
    if not data.get("playing"):
        print("🎵 Nothing playing right now.")
        return
    print(f"🎵 {data['artists']} — {data['title']}")
    if data.get("album"):
        print(f"   Album: {data['album']}")


def cmd_history():
    tracks = _get("/history", {"limit": 15})
    if not tracks:
        print("No listening history.")
        return
    print("🎵 Recent History:\n")
    for i, t in enumerate(tracks, 1):
        print(f"  {i:2}. {t['artists']} — {t['title']}")


def cmd_search(query: str, search_type: str = "songs"):
    results = _get("/search", {"q": query, "type": search_type})
    if not results:
        print(f"No {search_type} found for '{query}'.")
        return
    print(f"🔍 {search_type.title()} matching '{query}':\n")
    for i, item in enumerate(results[:15], 1):
        if search_type == "songs":
            print(f"  {i:2}. {item['artists']} — {item['title']}  [{item.get('video_id','')}]")
        elif search_type == "albums":
            print(f"  {i:2}. {item.get('artists','')} — {item['title']} ({item.get('year','')})")
        elif search_type == "artists":
            print(f"  {i:2}. {item['name']} ({item.get('subscribers','')})")
        elif search_type == "playlists":
            print(f"  {i:2}. {item['title']} by {item.get('author','')}")


def cmd_playlists():
    playlists = _get("/playlists")
    if not playlists:
        print("No playlists found.")
        return
    print("📋 Your Playlists:\n")
    for p in playlists:
        print(f"  {p['title']} ({p.get('count', '?')} tracks)  [{p['id']}]")


def cmd_playlist(playlist_id: str):
    data = _get(f"/playlist/{playlist_id}")
    print(f"📋 {data['title']} ({data.get('count', '?')} tracks):\n")
    for i, t in enumerate(data.get("tracks", [])[:25], 1):
        print(f"  {i:2}. {t['artists']} — {t['title']}")


def cmd_like(video_id: str):
    _post("/like", {"video_id": video_id})
    print(f"❤️ Liked!")


def cmd_recommend():
    data = _get("/recommend")
    recs = data.get("recommendations", [])
    if not recs:
        print("🤷 No recommendations yet.")
        return
    print(f"🎧 {data.get('reason', 'Recommendations')}:\n")
    for i, r in enumerate(recs[:10], 1):
        print(f"  {i:2}. {r['artists']} — {r['title']}  [{r.get('video_id','')}]")


def main():
    args = sys.argv[1:]

    if not args:
        cmd_now_playing()
        return

    cmd = args[0]

    if cmd == "history":
        cmd_history()
    elif cmd == "search":
        if len(args) < 2:
            print("Usage: jukebox search <query> [--type songs|albums|artists|playlists]")
            return
        query = args[1]
        search_type = "songs"
        if "--type" in args:
            idx = args.index("--type")
            if idx + 1 < len(args):
                search_type = args[idx + 1]
        cmd_search(query, search_type)
    elif cmd == "playlists":
        cmd_playlists()
    elif cmd == "playlist" and len(args) >= 2:
        cmd_playlist(args[1])
    elif cmd == "like" and len(args) >= 2:
        cmd_like(args[1])
    elif cmd == "recommend":
        cmd_recommend()
    else:
        print(__doc__)


if __name__ == "__main__":
    main()
